<div class="ps-section-header">
  <h2 class="ps-section-title">Find a spot</h2>
  <% if (currentUser) { %>
    <a href="/spots/new" class="btn btn-primary btn-sm">+ List your spot</a>
  <% } %>
</div>

<form class="filter-bar mb-4" method="get" action="/spots">
  <div class="row g-2 align-items-end">
    <div class="col-md-3">
      <label class="form-label">Search</label>
      <input name="q" class="form-control" value="<%= filters.q %>" placeholder="Street, zip, or area…" />
    </div>
    <div class="col-md-2">
      <label class="form-label">Type</label>
      <select name="type_id" class="form-select">
        <option value="">All types</option>
        <% types.forEach((t) => { %>
          <option value="<%= t.spot_type_id %>" <%= String(filters.type_id) === String(t.spot_type_id) ? 'selected' : '' %>>
            <%= t.type_name %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label">Max $/hr</label>
      <input type="number" step="0.01" name="max_price" class="form-control" value="<%= filters.max_price %>" placeholder="Any" />
    </div>
    <div class="col-md-2">
      <label class="form-label">Start</label>
      <input type="datetime-local" name="start" class="form-control" value="<%= filters.start %>" />
    </div>
    <div class="col-md-2">
      <label class="form-label">End</label>
      <input type="datetime-local" name="end" class="form-control" value="<%= filters.end %>" />
    </div>
    <div class="col-md-1">
      <label class="form-label">Sort</label>
      <select name="sort" class="form-select">
        <option value="price_asc"  <%= filters.sort === 'price_asc'  ? 'selected' : '' %>>$↑</option>
        <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>$↓</option>
        <option value="newest"     <%= filters.sort === 'newest'     ? 'selected' : '' %>>New</option>
      </select>
    </div>
  </div>
  <div class="mt-3 d-flex gap-2">
    <button class="btn btn-primary btn-sm" type="submit">Apply filters</button>
    <a href="/spots" class="btn btn-outline-secondary btn-sm">Clear</a>
    <% if (spots.length) { %>
      <span class="ms-auto" style="font-size:0.8rem;color:var(--text-muted);align-self:center">
        <%= spots.length %> spot<%= spots.length === 1 ? '' : 's' %>
      </span>
    <% } %>
  </div>
</form>

<% if (!spots.length) { %>
  <div class="alert alert-info">No spots match your filters. Try widening your search.</div>
<% } else { %>
  <div class="row g-3">
    <% spots.forEach((s) => { %>
      <div class="col-md-4 col-sm-6">
        <a href="/spots/<%= s.spot_id %>" class="text-decoration-none">
          <div class="card spot-card h-100">
            <% if (s.cover_photo) { %>
              <img src="<%= s.cover_photo %>" alt="Spot photo" onerror="this.parentElement.removeChild(this)" />
            <% } else { %>
              <div style="height:170px;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;">
                <span style="font-size:2.5rem;opacity:0.3">🅿️</span>
              </div>
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= s.street %></h5>
              <p style="font-size:0.8rem;color:var(--text-muted);margin-bottom:10px">
                <%= s.city %> · <span style="color:var(--accent-blue)"><%= s.type_name %></span>
              </p>
              <div class="d-flex justify-content-between align-items-center">
                <span class="spot-price">$<%= Number(s.hourly_rate).toFixed(2) %><span style="font-family:'DM Sans';font-size:0.8rem;font-weight:400;color:var(--text-muted)">/hr</span></span>
                <span style="font-size:0.75rem;color:var(--text-muted)"><%= s.host_first %></span>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
<% } %>
