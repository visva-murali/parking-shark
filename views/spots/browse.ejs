<!-- Page header -->
<div class="ps-section-header mb-3">
  <h1 class="ps-page-title">
    <% if (filters.q) { %>Spots near "<%= filters.q %>"
    <% } else { %>Available spots<% } %>
    <span style="font-size:16px;font-weight:400;color:var(--text-3);margin-left:8px"><%= spots.length %> result<%= spots.length === 1 ? '' : 's' %></span>
  </h1>
  <% if (currentUser) { %>
    <a href="/spots/new" class="btn btn-primary btn-sm">+ List your spot</a>
  <% } %>
</div>

<!-- Type filter chips -->
<div class="ps-type-chips mb-4">
  <a href="/spots<%= filters.q ? '?q=' + filters.q : '' %>" class="ps-chip <%= !filters.type_id ? 'active' : '' %>">All</a>
  <% types.forEach((t) => { %>
    <a href="/spots?type_id=<%= t.spot_type_id %><%= filters.q ? '&q=' + filters.q : '' %>"
       class="ps-chip <%= String(filters.type_id) === String(t.spot_type_id) ? 'active' : '' %>">
      <%= t.type_name %>
    </a>
  <% }) %>
</div>

<!-- Filter bar (collapsed by default, shown on expand) -->
<details style="margin-bottom:24px">
  <summary style="cursor:pointer;font-size:13.5px;font-weight:600;color:var(--text-2);list-style:none;display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:1.5px solid var(--border);border-radius:var(--radius-pill);background:var(--white)">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
    Filters
    <% if (filters.max_price || filters.start || filters.end) { %><span style="background:var(--text);color:#fff;border-radius:50%;width:18px;height:18px;display:inline-flex;align-items:center;justify-content:center;font-size:10px">•</span><% } %>
  </summary>
  <form method="get" action="/spots" style="margin-top:12px">
    <input type="hidden" name="type_id" value="<%= filters.type_id %>" />
    <div class="filter-bar">
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Search</label>
          <input name="q" class="form-control" value="<%= filters.q %>" placeholder="Street or zip…" />
        </div>
        <div class="col-md-2">
          <label class="form-label">Max price / hr</label>
          <input type="number" step="0.50" name="max_price" class="form-control" value="<%= filters.max_price %>" placeholder="Any" />
        </div>
        <div class="col-md-2">
          <label class="form-label">Available from</label>
          <input type="datetime-local" name="start" class="form-control" value="<%= filters.start %>" />
        </div>
        <div class="col-md-2">
          <label class="form-label">Available until</label>
          <input type="datetime-local" name="end" class="form-control" value="<%= filters.end %>" />
        </div>
        <div class="col-md-2">
          <label class="form-label">Sort by</label>
          <select name="sort" class="form-select">
            <option value="price_asc"  <%= filters.sort === 'price_asc'  ? 'selected' : '' %>>Price: low to high</option>
            <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Price: high to low</option>
            <option value="newest"     <%= filters.sort === 'newest'     ? 'selected' : '' %>>Newest</option>
          </select>
        </div>
        <div class="col-md-1 d-flex gap-2">
          <button class="btn btn-primary btn-sm w-100" type="submit">Apply</button>
        </div>
      </div>
      <% if (filters.q || filters.max_price || filters.start || filters.end || filters.type_id) { %>
        <div style="margin-top:12px"><a href="/spots" class="btn-link" style="font-size:13px">Clear all filters</a></div>
      <% } %>
    </div>
  </form>
</details>

<!-- Live price filter -->
<% if (spots.length) { %>
  <%
    const _prices = spots.map(s => parseFloat(s.hourly_rate));
    const _pMin = Math.min(..._prices);
  %>
  <div id="price-filter-bar"
       data-min="<%= _pMin.toFixed(2) %>"
       data-max="<%= globalMax.toFixed(2) %>"
       data-active="<%= filters.max_price || '' %>"
       style="margin-bottom:24px;padding:16px 20px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--border-light)">
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px">
      <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-3)">Max price / hr</span>
      <span id="live-price-label" style="font-size:17px;font-weight:700;color:var(--text)">Any price</span>
    </div>
    <input type="range" id="live-price-filter" step="0.50"
           style="width:100%;accent-color:var(--accent);cursor:pointer" />
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px">
      <span style="font-size:12px;color:var(--text-4)">$<%= _pMin.toFixed(2) %></span>
      <span id="live-spot-count" style="font-size:12px;font-weight:500;color:var(--accent)"></span>
      <span style="font-size:12px;color:var(--text-4)">$<%= _pMax.toFixed(2) %></span>
    </div>
  </div>
<% } %>

<!-- Spot grid -->
<% if (!spots.length) { %>
  <div class="alert alert-info">No spots match your filters. Try adjusting your search.</div>
<% } else { %>
  <div class="row g-4" id="spots-grid">
    <% spots.forEach((s) => { %>
      <div class="col-6 col-md-4 col-xl-3" data-price="<%= Number(s.hourly_rate).toFixed(2) %>">
        <a href="/spots/<%= s.spot_id %>" style="text-decoration:none;display:block">
          <div class="spot-card">
            <div class="spot-card-img-wrap">
              <% if (s.cover_photo) { %>
                <img src="<%= s.cover_photo %>" class="spot-card-img" alt="Parking spot at <%= s.street %>" loading="lazy" onerror="this.parentElement.innerHTML='<div class=\'spot-card-img-placeholder\'>🅿️</div>'" />
              <% } else { %>
                <div class="spot-card-img-placeholder">🅿️</div>
              <% } %>
            </div>
            <div class="spot-card-body">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
                <p class="spot-card-title"><%= s.street %></p>
              </div>
              <p class="spot-card-sub"><%= s.city %> · <%= s.type_name %></p>
              <p class="spot-card-price"><strong>$<%= Number(s.hourly_rate).toFixed(2) %></strong><span> / hr</span></p>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
<% } %>
