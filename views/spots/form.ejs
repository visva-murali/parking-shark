<div class="row justify-content-center">
  <div class="col-lg-7">
    <div style="margin-bottom:28px">
      <h1 style="font-size:26px;font-weight:700;color:var(--text);letter-spacing:-0.01em;margin-bottom:6px">
        <%= spot ? 'Edit your listing' : 'List your parking spot' %>
      </h1>
      <p style="font-size:14px;color:var(--text-3)">
        <%= spot ? 'Update the details below.' : 'Takes about 2 minutes. Start earning today.' %>
      </p>
    </div>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger mb-4">
        <ul style="margin:0;padding-left:18px;font-size:13.5px">
          <% errors.forEach((e) => { %><li><%= e.msg %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form method="post" action="<%= spot ? '/spots/' + spot.spot_id + '/edit' : '/spots' %>">

      <% if (!spot) { %>
        <div class="card mb-4">
          <div class="card-body">
            <h2 style="font-size:16px;font-weight:600;color:var(--text);margin-bottom:16px">Location</h2>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Street address</label>
                <input name="street" class="form-control" value="<%= form.street || '' %>" required placeholder="123 Jefferson Park Ave" />
              </div>
              <div class="col-md-5">
                <label class="form-label">City</label>
                <input name="city" class="form-control" value="<%= form.city || 'Charlottesville' %>" required />
              </div>
              <div class="col-md-3">
                <label class="form-label">State</label>
                <input name="state" maxlength="2" class="form-control" value="<%= form.state || 'VA' %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Zip code</label>
                <input name="zip_code" class="form-control" value="<%= form.zip_code || '22903' %>" required />
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <div class="card mb-4">
        <div class="card-body">
          <h2 style="font-size:16px;font-weight:600;color:var(--text);margin-bottom:16px">Spot details</h2>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Spot type</label>
              <select name="spot_type_id" class="form-select" required>
                <% types.forEach((t) => { %>
                  <option value="<%= t.spot_type_id %>" <%= Number(form.spot_type_id) === t.spot_type_id ? 'selected' : '' %>>
                    <%= t.type_name %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Hourly rate (USD)</label>
              <div style="position:relative">
                <span style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-3);font-size:14px">$</span>
                <input type="number" step="0.01" min="0.01" name="hourly_rate" class="form-control"
                       value="<%= form.hourly_rate || '5.00' %>" required style="padding-left:26px" />
              </div>
            </div>
            <div class="col-12">
              <label class="form-label">
                Instructions
                <span style="color:var(--text-4);text-transform:none;letter-spacing:0;font-weight:400;font-size:11px"> — visible to renters after booking</span>
              </label>
              <textarea name="instructions" class="form-control" rows="3"
                        placeholder="e.g. 'Pull into the left driveway, do not block the garage.'"><%= form.instructions || '' %></textarea>
            </div>
            <% if (!spot) { %>
              <div class="col-12">
                <label class="form-label">Cover photo URL</label>
                <input name="photo_url" class="form-control" value="<%= form.photo_url || '' %>" placeholder="https://i.ibb.co/example/photo.jpg" required />
                <details style="margin-top:10px">
                  <summary style="cursor:pointer;font-size:13px;font-weight:600;color:var(--accent);user-select:none">How do I get a free image URL? ▸</summary>
                  <div style="margin-top:10px;padding:14px 16px;background:var(--off-white);border-left:3px solid var(--accent);border-radius:0 6px 6px 0;font-size:13px;color:var(--text-2);line-height:1.7">
                    <p style="margin:0 0 8px 0;font-weight:600;color:var(--text)">Option 1 — ImgBB (recommended)</p>
                    <ol style="margin:0 0 12px 0;padding-left:18px">
                      <li>Go to <a href="https://imgbb.com" target="_blank" rel="noopener noreferrer" style="color:var(--accent)">imgbb.com</a></li>
                      <li>Click <strong>Choose photo</strong> and select your image</li>
                      <li>Click <strong>Upload</strong></li>
                      <li>Under the uploaded image, click <strong>Copy</strong> next to <em>Direct link</em></li>
                      <li>Paste that URL into the field above</li>
                    </ol>
                    <p style="margin:0;color:var(--text-3)">Option 2 — <a href="https://postimages.org" target="_blank" rel="noopener noreferrer" style="color:var(--accent)">Postimages.org</a>: upload → copy the <em>Direct link</em> URL. No account needed on either service.</p>
                  </div>
                </details>
              </div>
            <% } %>
            <% if (spot) { %>
              <div class="col-12">
                <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
                  <input type="checkbox" name="is_active" class="form-check-input" style="margin:0;width:18px;height:18px"
                    <%= (form.is_active === 'on' || form.is_active === true || form.is_active == 1) ? 'checked' : '' %> />
                  <span style="font-size:14px;color:var(--text-2)">Active — visible to renters</span>
                </label>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit" style="border-radius:var(--radius);padding:12px 28px">
          <%= spot ? 'Save changes' : 'List your spot' %>
        </button>
        <a href="<%= spot ? '/spots/' + spot.spot_id : '/spots' %>" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
