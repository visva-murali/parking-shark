<div class="row justify-content-center">
  <div class="col-lg-8">
    <!-- Header -->
    <div class="mb-4">
      <h1 style="font-family:'Barlow Condensed';font-size:2.4rem;font-weight:800;margin-bottom:4px">
        <%= spot ? 'Edit listing' : 'List your driveway' %>
      </h1>
      <p style="color:var(--text-muted);margin:0">
        <%= spot ? 'Update your spot details below.' : 'Turn your driveway into income. Takes 2 minutes.' %>
      </p>
    </div>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger mb-4">
        <ul class="mb-0 ps-3">
          <% errors.forEach((e) => { %>
            <li><%= e.msg %><% if (e.path) { %> <span style="opacity:0.7">(<%= e.path %>)</span><% } %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="post" action="<%= spot ? '/spots/' + spot.spot_id + '/edit' : '/spots' %>">

      <% if (!spot) { %>
        <!-- ── Address section ── -->
        <div class="card mb-4">
          <div class="card-body">
            <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:14px">Location</p>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Street address</label>
                <input name="street" class="form-control" value="<%= form.street || '' %>" required placeholder="123 Jefferson Park Ave" />
              </div>
              <div class="col-md-5">
                <label class="form-label">City</label>
                <input name="city" class="form-control" value="<%= form.city || 'Charlottesville' %>" required />
              </div>
              <div class="col-md-3">
                <label class="form-label">State</label>
                <input name="state" maxlength="2" class="form-control" value="<%= form.state || 'VA' %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Zip code</label>
                <input name="zip_code" class="form-control" value="<%= form.zip_code || '22903' %>" required />
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ── Spot details section ── -->
      <div class="card mb-4">
        <div class="card-body">
          <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:14px">Spot details</p>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Spot type</label>
              <select name="spot_type_id" class="form-select" required>
                <% types.forEach((t) => { %>
                  <option value="<%= t.spot_type_id %>" <%= Number(form.spot_type_id) === t.spot_type_id ? 'selected' : '' %>>
                    <%= t.type_name %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Hourly rate ($)</label>
              <input type="number" step="0.01" min="0.01" name="hourly_rate" class="form-control"
                     value="<%= form.hourly_rate || '5.00' %>" required />
            </div>
            <div class="col-12">
              <label class="form-label">
                Instructions
                <span style="color:var(--text-subtle);font-size:0.75rem;text-transform:none;letter-spacing:0">(optional)</span>
              </label>
              <textarea name="instructions" class="form-control" rows="3"
                        placeholder="e.g. Pull into driveway on left. Do not block garage."><%= form.instructions || '' %></textarea>
            </div>
            <% if (!spot) { %>
              <div class="col-12">
                <label class="form-label">
                  Photo URL
                  <span style="color:var(--text-subtle);font-size:0.75rem;text-transform:none;letter-spacing:0">(optional, can add more later)</span>
                </label>
                <input name="photo_url" class="form-control" value="<%= form.photo_url || '' %>" placeholder="https://…" />
              </div>
            <% } %>
            <% if (spot) { %>
              <div class="col-12">
                <div class="form-check">
                  <input type="checkbox" name="is_active" class="form-check-input" id="isActive"
                    <%= (form.is_active === 'on' || form.is_active === true || form.is_active == 1) ? 'checked' : '' %> />
                  <label for="isActive" class="form-check-label" style="font-size:0.875rem;color:var(--text);text-transform:none;letter-spacing:0;font-weight:400">
                    Active — visible to renters
                  </label>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit" style="padding:10px 28px">
          <%= spot ? 'Save changes' : 'List it' %>
        </button>
        <a href="<%= spot ? '/spots/' + spot.spot_id : '/spots' %>" class="btn btn-outline-secondary">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>
