<div class="row g-4">

  <!-- ── Left: reservation details ── -->
  <div class="col-lg-8">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <p style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:4px">
          Reservation #<%= r.reservation_id %>
        </p>
        <h1 style="font-family:'Barlow Condensed';font-size:2.2rem;font-weight:800;margin:0;line-height:1">
          <%= r.street %>
        </h1>
        <p style="color:var(--text-muted);margin:4px 0 0;font-size:0.9rem">
          <%= r.city %>, <%= r.state %> &middot; <%= r.type_name %>
        </p>
      </div>
      <span class="badge bg-<%= {Pending:'warning',Confirmed:'primary',Completed:'success',Cancelled:'secondary'}[r.status_name] || 'secondary' %>"
            style="font-size:0.75rem;padding:6px 12px;align-self:flex-start">
        <%= r.status_name %>
      </span>
    </div>

    <!-- Cost band -->
    <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.2rem 1.5rem;margin-bottom:1.5rem;display:flex;justify-content:space-between;align-items:center">
      <div>
        <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin:0 0 2px">Total</p>
        <span style="font-family:'Barlow Condensed';font-size:2.4rem;font-weight:800;color:var(--accent);line-height:1">
          $<%= Number(r.total_cost).toFixed(2) %>
        </span>
      </div>
      <div style="text-align:right">
        <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin:0 0 2px">Rate at booking</p>
        <span style="font-family:'Barlow Condensed';font-size:1.3rem;font-weight:600;color:var(--text)">
          $<%= Number(r.hourly_rate_at_booking).toFixed(2) %><span style="font-family:'DM Sans';font-size:0.8rem;color:var(--text-muted)">/hr</span>
        </span>
      </div>
    </div>

    <!-- Info cards row -->
    <div class="row g-3 mb-3">
      <!-- When -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-body">
            <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:10px">When</p>
            <div style="display:flex;flex-direction:column;gap:6px;font-size:0.875rem">
              <div class="d-flex justify-content-between">
                <span style="color:var(--text-muted)">Start</span>
                <span style="color:var(--text);font-weight:500"><%= new Date(r.start_time).toLocaleString() %></span>
              </div>
              <div class="d-flex justify-content-between">
                <span style="color:var(--text-muted)">End</span>
                <span style="color:var(--text);font-weight:500"><%= new Date(r.end_time).toLocaleString() %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Vehicle -->
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-body">
            <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:10px">Vehicle</p>
            <p style="font-weight:600;color:var(--text);margin-bottom:3px">
              <%= r.year || '' %> <%= r.make %> <%= r.model %>
            </p>
            <p style="font-size:0.8rem;color:var(--text-muted);margin:0">
              <%= r.color || '' %><% if (r.license_plate) { %> &middot; <%= r.license_plate %> (<%= r.plate_state %>)<% } %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment -->
    <% if (r.payment_id) { %>
      <div class="card mb-3">
        <div class="card-body">
          <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:10px">Payment</p>
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <span style="font-size:0.9rem;color:var(--text)">$<%= Number(r.amount).toFixed(2) %></span>
              <span style="color:var(--text-muted);margin:0 8px">&middot;</span>
              <span style="font-size:0.85rem;color:var(--text-muted)"><%= r.method || '—' %></span>
            </div>
            <span class="badge bg-<%= r.payment_status==='Paid' ? 'success' : r.payment_status==='Refunded' ? 'secondary' : 'warning' %>">
              <%= r.payment_status %>
            </span>
          </div>
          <% if (r.paid_at) { %>
            <p style="font-size:0.75rem;color:var(--text-muted);margin-top:6px;margin-bottom:0">
              Paid <%= new Date(r.paid_at).toLocaleString() %>
            </p>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Review section (renter, completed only) -->
    <% if (roles.isRenter && r.status_name === 'Completed') { %>
      <div class="card">
        <div class="card-body">
          <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:14px">
            <%= review ? 'Your review' : 'Leave a review' %>
          </p>
          <form method="post" action="/reservations/<%= r.reservation_id %>/review">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Rating</label>
                <select name="rating" class="form-select">
                  <% for (let i = 5; i >= 1; i--) { %>
                    <option value="<%= i %>" <%= review && review.rating === i ? 'selected' : '' %>>
                      <%= '★'.repeat(i) + '☆'.repeat(5-i) %> &nbsp;<%= i %>/5
                    </option>
                  <% } %>
                </select>
              </div>
              <div class="col-md-8">
                <label class="form-label">Comment</label>
                <textarea name="comment" class="form-control" rows="2" placeholder="How was the spot?"><%= review ? review.comment || '' : '' %></textarea>
              </div>
            </div>
            <div class="d-flex gap-2 mt-3">
              <button class="btn btn-primary btn-sm"><%= review ? 'Update review' : 'Post review' %></button>
              <% if (review) { %>
                <form method="post" action="/reservations/<%= r.reservation_id %>/review/delete" class="d-inline">
                  <button class="btn btn-outline-danger btn-sm">Delete</button>
                </form>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    <% } %>
  </div>

  <!-- ── Right: actions ── -->
  <div class="col-lg-4">
    <div class="card sticky-top">
      <div class="card-body">
        <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:14px">Actions</p>

        <div style="display:flex;flex-direction:column;gap:10px">
          <% if (roles.isHost && r.status_name === 'Pending') { %>
            <form method="post" action="/reservations/<%= r.reservation_id %>/status">
              <input type="hidden" name="action" value="confirm" />
              <button class="btn btn-primary w-100">Confirm booking</button>
            </form>
          <% } %>
          <% if (roles.isHost && r.status_name === 'Confirmed') { %>
            <form method="post" action="/reservations/<%= r.reservation_id %>/status">
              <input type="hidden" name="action" value="complete" />
              <button class="btn btn-success w-100">Mark complete</button>
            </form>
          <% } %>
          <% if (['Pending','Confirmed'].includes(r.status_name)) { %>
            <form method="post" action="/reservations/<%= r.reservation_id %>/status">
              <input type="hidden" name="action" value="cancel" />
              <button class="btn btn-outline-danger w-100">Cancel reservation</button>
            </form>
          <% } %>

          <% if (roles.isRenter && ['Pending','Confirmed'].includes(r.status_name)) { %>
            <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:2px">
              <p style="font-size:0.75rem;color:var(--text-muted);margin-bottom:8px">Extend end time</p>
              <form method="post" action="/reservations/<%= r.reservation_id %>/extend">
                <input type="datetime-local" name="end_time" class="form-control mb-2" required />
                <button class="btn btn-outline-primary w-100 btn-sm">Extend</button>
              </form>
            </div>
          <% } %>

          <% if (r.payment_status === 'Pending' && roles.isRenter) { %>
            <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:2px">
              <form method="post" action="/reservations/<%= r.reservation_id %>/pay">
                <button class="btn btn-success w-100">Mark as paid</button>
              </form>
            </div>
          <% } %>

          <% if (r.status_name === 'Cancelled') { %>
            <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:2px">
              <form method="post" action="/reservations/<%= r.reservation_id %>/delete"
                    onsubmit="return confirm('Permanently delete this reservation?')">
                <button class="btn btn-outline-danger w-100 btn-sm">Delete permanently</button>
              </form>
            </div>
          <% } %>
        </div>

        <div style="border-top:1px solid var(--border);padding-top:14px;margin-top:14px">
          <a href="/spots/<%= r.spot_id %>" style="color:var(--accent);font-size:0.85rem;text-decoration:none">
            ← View spot listing
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
