<div class="row g-5">
  <!-- LEFT -->
  <div class="col-lg-8">
    <div style="margin-bottom:24px">
      <a href="/spots/<%= r.spot_id %>" style="font-size:13px;color:var(--text-3);text-decoration:none;display:inline-flex;align-items:center;gap:4px;margin-bottom:12px">
        ← Back to listing
      </a>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px">
        <div>
          <h1 style="font-size:24px;font-weight:700;color:var(--text);letter-spacing:-0.01em;margin-bottom:4px"><%= r.street %></h1>
          <p style="font-size:14px;color:var(--text-3)"><%= r.city %>, <%= r.state %> · <%= r.type_name %></p>
        </div>
        <span class="badge bg-<%= {Pending:'warning',Confirmed:'primary',Completed:'success',Cancelled:'secondary'}[r.status_name] %>" style="white-space:nowrap;margin-top:4px">
          <%= r.status_name %>
        </span>
      </div>
    </div>

    <!-- Cost -->
    <div style="background:var(--off-white);border-radius:var(--radius-lg);padding:20px 24px;margin-bottom:24px;display:flex;justify-content:space-between;align-items:center">
      <div>
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);margin-bottom:4px">Total cost</p>
        <span style="font-size:30px;font-weight:800;color:var(--text);letter-spacing:-0.02em">$<%= Number(r.total_cost).toFixed(2) %></span>
      </div>
      <div style="text-align:right">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);margin-bottom:4px">Rate</p>
        <span style="font-size:16px;font-weight:600;color:var(--text-2)">$<%= Number(r.hourly_rate_at_booking).toFixed(2) %>/hr</span>
      </div>
    </div>

    <!-- Info grid -->
    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);margin-bottom:12px">Dates & times</p>
            <div style="display:flex;flex-direction:column;gap:8px;font-size:14px">
              <div style="display:flex;justify-content:space-between">
                <span style="color:var(--text-3)">Start</span>
                <span style="color:var(--text);font-weight:500"><%= new Date(r.start_time).toLocaleString() %></span>
              </div>
              <div style="border-top:1px solid var(--border-light);padding-top:8px;display:flex;justify-content:space-between">
                <span style="color:var(--text-3)">End</span>
                <span style="color:var(--text);font-weight:500"><%= new Date(r.end_time).toLocaleString() %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);margin-bottom:12px">Vehicle</p>
            <p style="font-weight:600;color:var(--text);font-size:15px;margin-bottom:3px"><%= r.year || '' %> <%= r.make %> <%= r.model %></p>
            <p style="font-size:13px;color:var(--text-3);margin:0">
              <%= r.color || '' %>
              <% if (r.license_plate) { %> · <%= r.license_plate %> (<%= r.plate_state %>)<% } %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment -->
    <% if (r.payment_id) { %>
      <div class="card mb-4">
        <div class="card-body">
          <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);margin-bottom:12px">Payment</p>
          <div style="display:flex;justify-content:space-between;align-items:center;font-size:14px">
            <span style="color:var(--text-2)">$<%= Number(r.amount).toFixed(2) %> via <%= r.method || '—' %></span>
            <span class="badge bg-<%= r.payment_status==='Paid'?'success':r.payment_status==='Refunded'?'secondary':'warning' %>">
              <%= r.payment_status %>
            </span>
          </div>
          <% if (r.paid_at) { %>
            <p style="font-size:12px;color:var(--text-3);margin-top:6px;margin-bottom:0">Paid <%= new Date(r.paid_at).toLocaleString() %></p>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Review (renter, completed) -->
    <% if (roles.isRenter && r.status_name === 'Completed') { %>
      <div class="card">
        <div class="card-body">
          <h3 style="font-size:16px;font-weight:600;color:var(--text);margin-bottom:16px">
            <%= review ? 'Your review' : 'Leave a review' %>
          </h3>
          <form method="post" action="/reservations/<%= r.reservation_id %>/review">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Rating</label>
                <select name="rating" class="form-select">
                  <% for (let i = 5; i >= 1; i--) { %>
                    <option value="<%= i %>" <%= review && review.rating === i ? 'selected' : '' %>>
                      <%= '★'.repeat(i) + '☆'.repeat(5-i) %> &nbsp;<%= i %>/5
                    </option>
                  <% } %>
                </select>
              </div>
              <div class="col-md-8">
                <label class="form-label">Comment</label>
                <textarea name="comment" class="form-control" rows="2" placeholder="How was the spot?"><%= review ? review.comment || '' : '' %></textarea>
              </div>
            </div>
            <div style="margin-top:14px;display:flex;gap:10px;align-items:center">
              <button class="btn btn-primary btn-sm"><%= review ? 'Update' : 'Post review' %></button>
              <% if (review) { %>
                <form method="post" action="/reservations/<%= r.reservation_id %>/review/delete" class="d-inline">
                  <button class="btn btn-ghost btn-sm" style="color:var(--text-3);font-size:13px">Delete review</button>
                </form>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    <% } %>
  </div>

  <!-- RIGHT: actions -->
  <div class="col-lg-4">
    <div class="card" style="position:sticky;top:calc(var(--nav-h) + 16px)">
      <div class="card-body">
        <h3 style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:16px">Manage reservation</h3>
        <div style="display:flex;flex-direction:column;gap:10px">

          <% if (roles.isHost && r.status_name === 'Pending') { %>
            <form method="post" action="/reservations/<%= r.reservation_id %>/status">
              <input type="hidden" name="action" value="confirm" />
              <button class="btn btn-primary w-100">Confirm booking</button>
            </form>
          <% } %>
          <% if (roles.isHost && r.status_name === 'Confirmed') { %>
            <form method="post" action="/reservations/<%= r.reservation_id %>/status">
              <input type="hidden" name="action" value="complete" />
              <button class="btn btn-success w-100">Mark complete</button>
            </form>
          <% } %>
          <% if (['Pending','Confirmed'].includes(r.status_name)) { %>
            <form method="post" action="/reservations/<%= r.reservation_id %>/status">
              <input type="hidden" name="action" value="cancel" />
              <button class="btn btn-outline w-100" style="border-color:var(--danger-c);color:var(--danger-c)">Cancel reservation</button>
            </form>
          <% } %>

          <% if (roles.isRenter && ['Pending','Confirmed'].includes(r.status_name)) { %>
            <hr style="border-color:var(--border-light);margin:4px 0" />
            <div>
              <p style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3);margin-bottom:8px">Extend end time</p>
              <form method="post" action="/reservations/<%= r.reservation_id %>/extend">
                <input type="datetime-local" name="end_time" class="form-control mb-2" required />
                <button class="btn btn-outline w-100 btn-sm">Extend</button>
              </form>
            </div>
          <% } %>

          <% if (r.payment_status === 'Pending' && roles.isRenter) { %>
            <hr style="border-color:var(--border-light);margin:4px 0" />
            <form method="post" action="/reservations/<%= r.reservation_id %>/pay">
              <button class="btn btn-success w-100">Mark as paid</button>
            </form>
          <% } %>

          <% if (r.status_name === 'Cancelled') { %>
            <hr style="border-color:var(--border-light);margin:4px 0" />
            <form method="post" action="/reservations/<%= r.reservation_id %>/delete"
                  onsubmit="return confirm('Permanently delete this reservation?')">
              <button class="btn btn-outline btn-sm w-100" style="border-color:var(--danger-c);color:var(--danger-c)">
                Delete permanently
              </button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
