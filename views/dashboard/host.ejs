<div class="ps-section-header mb-4">
  <div>
    <h1 class="ps-page-title">Hosting</h1>
    <% if (rating.avg_rating) { %>
      <p style="font-size:13px;color:var(--text-3);margin:4px 0 0">
        ★ <%= rating.avg_rating %> overall · <%= rating.total_reviews %> review<%= rating.total_reviews == 1 ? '' : 's' %>
      </p>
    <% } %>
  </div>
  <div class="d-flex gap-2">
    <a href="/export/host-bookings.csv" class="btn btn-outline btn-sm">↓ Export</a>
    <a href="/spots/new" class="btn btn-primary btn-sm">+ New listing</a>
  </div>
</div>

<!-- Listings -->
<% if (!spots.length) { %>
  <div style="text-align:center;padding:48px 0;color:var(--text-3);margin-bottom:48px;border:1.5px dashed var(--border);border-radius:var(--radius-xl)">
    <div style="font-size:2rem;margin-bottom:12px">🏠</div>
    <p style="font-size:15px;font-weight:500;color:var(--text-2);margin-bottom:6px">No listings yet</p>
    <p style="font-size:13px;margin-bottom:16px">Start earning by listing your driveway or parking space.</p>
    <a href="/spots/new" class="btn btn-primary">List your spot</a>
  </div>
<% } else { %>
  <div class="row g-3 mb-5">
    <% spots.forEach((s) => { %>
      <div class="col-md-4 col-sm-6">
        <div class="card">
          <div class="card-body">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px">
              <span style="font-size:12px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.05em"><%= s.type_name %></span>
              <span class="badge bg-<%= s.is_active ? 'success' : 'secondary' %>"><%= s.is_active ? 'Active' : 'Inactive' %></span>
            </div>
            <p style="font-weight:600;color:var(--text);font-size:14.5px;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= s.street %></p>
            <p style="font-size:13px;color:var(--text-3);margin-bottom:14px"><%= s.city %></p>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <span style="font-size:15px;font-weight:700;color:var(--text)">$<%= Number(s.hourly_rate).toFixed(2) %><span style="font-size:12px;font-weight:400;color:var(--text-3)">/hr</span></span>
              <span style="font-size:12px;color:var(--text-3)"><%= s.total_bookings %> booking<%= s.total_bookings == 1 ? '' : 's' %></span>
            </div>
          </div>
          <div style="padding:0 16px 16px">
            <a href="/spots/<%= s.spot_id %>/edit" class="btn btn-outline btn-sm w-100">Manage</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<!-- Bookings -->
<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
  <h2 class="ps-section-title">Reservations</h2>
  <% const pending = bookings.filter(b => b.status_name === 'Pending').length;
     if (pending) { %>
    <span class="badge bg-warning"><%= pending %> need action</span>
  <% } %>
</div>

<% if (!bookings.length) { %>
  <p style="font-size:14px;color:var(--text-3);margin-bottom:48px">No reservations yet.</p>
<% } else { %>
  <div class="table-responsive mb-5">
    <table class="table">
      <thead>
        <tr>
          <th>Renter</th>
          <th>Spot</th>
          <th>Date</th>
          <th>Vehicle</th>
          <th>Total</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% bookings.forEach((b) => { %>
          <tr>
            <td>
              <div style="font-weight:500;font-size:14px"><%= b.renter_first %> <%= b.renter_last %></div>
              <div style="font-size:12px;color:var(--text-3)"><%= b.email %></div>
            </td>
            <td style="font-size:13px;color:var(--text-2)"><%= b.street %></td>
            <td style="font-size:13px">
              <div style="color:var(--text-2)"><%= new Date(b.start_time).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></div>
              <div style="color:var(--text-3)">
                <%= new Date(b.start_time).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %> – <%= new Date(b.end_time).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %>
              </div>
            </td>
            <td style="font-size:13px;color:var(--text-2)">
              <%= b.make %> <%= b.model %>
              <% if (b.license_plate) { %><div style="font-size:12px;color:var(--text-3)"><%= b.license_plate %></div><% } %>
            </td>
            <td style="font-size:14px;font-weight:600;color:var(--text)">$<%= Number(b.total_cost).toFixed(2) %></td>
            <td>
              <span class="badge bg-<%= {Pending:'warning',Confirmed:'primary',Completed:'success',Cancelled:'secondary'}[b.status_name] || 'secondary' %>">
                <%= b.status_name %>
              </span>
            </td>
            <td style="white-space:nowrap">
              <div class="d-flex gap-1">
                <a href="/reservations/<%= b.reservation_id %>" class="btn btn-outline btn-sm">View</a>
                <% if (b.status_name === 'Pending') { %>
                  <button class="btn btn-primary btn-sm" data-status-action="confirm" data-res-id="<%= b.reservation_id %>">Confirm</button>
                <% } else if (b.status_name === 'Confirmed') { %>
                  <button class="btn btn-success btn-sm" data-status-action="complete" data-res-id="<%= b.reservation_id %>">Complete</button>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<!-- Reviews -->
<h2 class="ps-section-title mb-3">Reviews</h2>
<% if (!reviews.length) { %>
  <p style="font-size:14px;color:var(--text-3)">No reviews yet.</p>
<% } else { %>
  <div class="row g-3">
    <% reviews.forEach((rv) => { %>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <div style="display:flex;justify-content:space-between;margin-bottom:8px">
              <span style="color:#F59E0B;font-size:13px;letter-spacing:1px">
                <%= '★'.repeat(rv.rating) %><%= '☆'.repeat(5-rv.rating) %>
              </span>
              <span style="font-size:12px;color:var(--text-3)"><%= new Date(rv.created_at).toLocaleDateString() %></span>
            </div>
            <p style="font-size:14px;color:var(--text-2);line-height:1.55;margin-bottom:10px"><%= rv.comment || '—' %></p>
            <p style="font-size:12px;color:var(--text-3);margin:0">
              <%= rv.renter_first %> <%= rv.renter_last %> · <%= rv.street %>
            </p>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
