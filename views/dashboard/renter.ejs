<div class="ps-section-header mb-4">
  <h1 class="ps-page-title">My bookings</h1>
  <a href="/export/reservations.csv" class="btn btn-outline btn-sm">↓ Export CSV</a>
</div>

<% if (!reservations.length) { %>
  <div style="text-align:center;padding:64px 0;color:var(--text-3)">
    <div style="font-size:2.5rem;margin-bottom:16px">🅿️</div>
    <p style="font-size:16px;font-weight:500;color:var(--text-2);margin-bottom:8px">No bookings yet</p>
    <p style="font-size:14px;margin-bottom:20px">Find and reserve a parking spot near campus.</p>
    <a href="/spots" class="btn btn-primary">Find a spot</a>
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>Spot</th>
          <th>Date</th>
          <th>Vehicle</th>
          <th>Total</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% reservations.forEach((r) => { %>
          <tr>
            <td>
              <div style="font-weight:600;color:var(--text);font-size:14px"><%= r.street %></div>
              <div style="font-size:12px;color:var(--text-3)"><%= r.city %></div>
            </td>
            <td style="font-size:13px">
              <div style="color:var(--text-2)"><%= new Date(r.start_time).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></div>
              <div style="color:var(--text-3)">
                <%= new Date(r.start_time).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %> –
                <%= new Date(r.end_time).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %>
              </div>
            </td>
            <td style="font-size:13px;color:var(--text-2)"><%= r.make %> <%= r.model %></td>
            <td style="font-size:14px;font-weight:600;color:var(--text)">$<%= Number(r.total_cost).toFixed(2) %></td>
            <td>
              <span class="badge bg-<%= {Pending:'warning',Confirmed:'primary',Completed:'success',Cancelled:'secondary'}[r.status_name] || 'secondary' %>">
                <%= r.status_name %>
              </span>
            </td>
            <td>
              <a href="/reservations/<%= r.reservation_id %>" class="btn btn-outline btn-sm">View</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
