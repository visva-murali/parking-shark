<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="mb-0">My vehicles</h2>
  <a href="/vehicles/new" class="btn btn-primary">+ Add vehicle</a>
</div>

<% if (!vehicles.length) { %>
  <div class="alert alert-info">You haven't added any vehicles yet.</div>
<% } else { %>
  <div class="table-responsive">
    <table class="table align-middle bg-white shadow-sm">
      <thead>
        <tr>
          <th>Vehicle</th>
          <th>Plate</th>
          <th>Verified?</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% vehicles.forEach((v) => { %>
          <tr>
            <td>
              <%= v.year || '' %> <%= v.make %> <%= v.model %>
              <% if (v.color) { %> <span class="text-muted small">(<%= v.color %>)</span><% } %>
            </td>
            <td>
              <% if (v.license_plate) { %>
                <%= v.license_plate %> (<%= v.plate_state %>)
                <% if (v.expires_on) { %>
                  <div class="small text-muted">Expires <%= new Date(v.expires_on).toLocaleDateString() %></div>
                <% } %>
              <% } else { %>
                <span class="text-muted">none</span>
              <% } %>
            </td>
            <td>
              <% if (v.is_verified) { %>
                <span class="badge bg-success">Verified</span>
              <% } else if (v.license_plate) { %>
                <span class="badge bg-warning text-dark">Unverified</span>
              <% } else { %>
                —
              <% } %>
            </td>
            <td class="text-end">
              <% if (v.license_plate && !v.is_verified) { %>
                <form method="post" action="/vehicles/<%= v.vehicle_id %>/verify" class="d-inline">
                  <button class="btn btn-outline-success btn-sm">Verify</button>
                </form>
              <% } %>
              <% if (v.license_plate) { %>
                <form method="post" action="/vehicles/<%= v.vehicle_id %>/registration/delete" class="d-inline">
                  <button class="btn btn-outline-warning btn-sm">Remove plate</button>
                </form>
              <% } %>
              <form method="post" action="/vehicles/<%= v.vehicle_id %>/delete" class="d-inline" onsubmit="return confirm('Delete this vehicle?')">
                <button class="btn btn-outline-danger btn-sm">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
