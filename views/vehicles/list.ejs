<div class="ps-section-header mb-4">
  <h1 class="ps-page-title">Vehicles</h1>
  <a href="/vehicles/new" class="btn btn-primary btn-sm">+ Add vehicle</a>
</div>

<% if (!vehicles.length) { %>
  <div style="text-align:center;padding:48px 0;color:var(--text-3);border:1.5px dashed var(--border);border-radius:var(--radius-xl)">
    <div style="font-size:2rem;margin-bottom:12px">🚗</div>
    <p style="font-size:15px;font-weight:500;color:var(--text-2);margin-bottom:6px">No vehicles yet</p>
    <p style="font-size:13px;margin-bottom:16px">Add a vehicle to start booking spots.</p>
    <a href="/vehicles/new" class="btn btn-primary btn-sm">Add a vehicle</a>
  </div>
<% } else { %>
  <div style="display:flex;flex-direction:column;gap:1px;border:1px solid var(--border-light);border-radius:var(--radius-lg);overflow:hidden;background:var(--border-light)">
    <% vehicles.forEach((v) => { %>
      <div style="background:var(--white);padding:16px 20px;display:flex;align-items:center;gap:16px">
        <!-- Icon -->
        <div style="width:48px;height:48px;border-radius:var(--radius);background:var(--off-white);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0">
          🚗
        </div>

        <!-- Info -->
        <div style="flex:1;min-width:0">
          <div style="font-size:15px;font-weight:600;color:var(--text)">
            <%= v.year || '' %> <%= v.make %> <%= v.model %>
            <% if (v.color) { %><span style="font-weight:400;color:var(--text-3)"> · <%= v.color %></span><% } %>
          </div>
          <% if (v.license_plate) { %>
            <div style="font-size:13px;color:var(--text-3);margin-top:1px">
              <%= v.license_plate %> (<%= v.plate_state %>)
              <% if (v.expires_on) { %> · expires <%= new Date(v.expires_on).toLocaleDateString() %><% } %>
            </div>
          <% } else { %>
            <div style="font-size:13px;color:var(--text-4);margin-top:1px">No plate registered</div>
          <% } %>
        </div>

        <!-- Badge -->
        <div style="flex-shrink:0">
          <% if (v.is_verified) { %>
            <span class="badge bg-success">Verified</span>
          <% } else if (v.license_plate) { %>
            <span class="badge bg-warning">Unverified</span>
          <% } %>
        </div>

        <!-- Actions -->
        <div style="flex-shrink:0;display:flex;gap:6px">
          <% if (v.license_plate && !v.is_verified) { %>
            <form method="post" action="/vehicles/<%= v.vehicle_id %>/verify">
              <button class="btn btn-outline btn-sm">Verify</button>
            </form>
          <% } %>
          <% if (v.license_plate) { %>
            <form method="post" action="/vehicles/<%= v.vehicle_id %>/registration/delete">
              <button class="btn btn-outline btn-sm" style="color:var(--warning-c);border-color:var(--warning-c)">Remove plate</button>
            </form>
          <% } %>
          <form method="post" action="/vehicles/<%= v.vehicle_id %>/delete"
                onsubmit="return confirm('Delete this vehicle?')">
            <button class="btn btn-outline btn-sm" style="color:var(--danger-c);border-color:var(--danger-c)">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
