<div class="auth-wrap">
  <div class="auth-card">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:28px;margin-bottom:10px">🦈</div>
      <h1 style="font-size:22px;font-weight:700;color:var(--text);margin-bottom:6px">Welcome back</h1>
      <p style="font-size:14px;color:var(--text-3)">Log in to your Parking Shark account</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger mb-4" style="font-size:13.5px"><%= error %></div>
    <% } %>

    <form method="post" action="/login">
      <div class="mb-3">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-control" value="<%= form.email || '' %>"
               required autofocus placeholder="you@virginia.edu" />
      </div>
      <div class="mb-4">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required placeholder="Your password" />
      </div>
      <button class="btn btn-primary w-100" type="submit"
              style="border-radius:var(--radius);padding:13px;font-size:15px">
        Continue
      </button>
    </form>

    <div class="auth-divider">or</div>

    <p style="text-align:center;font-size:14px;color:var(--text-3)">
      Don't have an account?&nbsp;
      <a href="/register" style="color:var(--text);font-weight:700;text-decoration:underline">Sign up</a>
    </p>
  </div>
</div>
