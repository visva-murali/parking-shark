<div class="row justify-content-center" style="margin-top:2rem">
  <div class="col-md-6 col-sm-10">
    <div class="auth-card">
      <div class="mb-4">
        <h2 style="font-family:'Barlow Condensed';font-size:2rem;font-weight:700;margin-bottom:4px">Create account</h2>
        <p style="color:var(--text-muted);font-size:0.875rem;margin:0">Join the Charlottesville parking community.</p>
      </div>
      <% if (errors && errors.length) { %>
        <div class="alert alert-danger mb-3">
          <ul class="mb-0 ps-3">
            <% errors.forEach((e) => { %><li><%= e.msg %><% if (e.path) { %> (<%= e.path %>)<% } %></li><% }) %>
          </ul>
        </div>
      <% } %>
      <form method="post" action="/register">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">First name</label>
            <input name="first_name" class="form-control" value="<%= form.first_name || '' %>" required />
          </div>
          <div class="col-md-6">
            <label class="form-label">Last name</label>
            <input name="last_name" class="form-control" value="<%= form.last_name || '' %>" required />
          </div>
          <div class="col-md-6">
            <label class="form-label">Computing ID</label>
            <input name="computing_id" class="form-control" value="<%= form.computing_id || '' %>" required />
          </div>
          <div class="col-md-6">
            <label class="form-label">Phone <span style="color:var(--text-subtle)">(optional)</span></label>
            <input name="phone_number" class="form-control" value="<%= form.phone_number || '' %>" />
          </div>
          <div class="col-12">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" value="<%= form.email || '' %>" required />
          </div>
          <div class="col-12">
            <label class="form-label">Password <span style="color:var(--text-subtle)">(min 8 characters)</span></label>
            <input type="password" name="password" class="form-control" required />
          </div>
        </div>
        <button class="btn btn-primary w-100 mt-4" type="submit" style="padding:11px">Create account</button>
      </form>
      <p style="text-align:center;margin-top:1.25rem;margin-bottom:0;font-size:0.85rem;color:var(--text-muted)">
        Already have an account? <a href="/login" style="color:var(--accent);text-decoration:none">Log in</a>
      </p>
    </div>
  </div>
</div>
