<div class="ps-error">
  <div style="font-size:3rem;margin-bottom:20px;opacity:0.15;font-weight:800;letter-spacing:-2px;color:var(--text)">404</div>
  <h1 style="font-size:22px;font-weight:700;color:var(--text);margin-bottom:8px"><%= title %></h1>
  <p style="font-size:15px;color:var(--text-3);max-width:380px;line-height:1.6;margin-bottom:28px"><%= message %></p>
  <div class="d-flex gap-3">
    <a href="/" class="btn btn-primary">Go home</a>
    <a href="javascript:history.back()" class="btn btn-ghost">Go back</a>
  </div>
</div>
